#define fast_io ios_base::sync_with_stdio(0);cin.tie(0);
#define endl '\n'
typedef long long ll;
 
using namespace std;
 
void solve(){
  ll n, x, y; cin >> n >> x >> y;
  ll c1 = (n / x) - (n / lcm(x,y));
  ll c2 = (n / y) - (n / lcm(x,y));
  ll ans2 = c2 * (c2 + 1) / 2;
  ll ans1 = c1 * (n - c1 + 1 + n) / 2;
  cout << ans1 - ans2 << endl;
}
 
int main() {
  int t; cin >> t;
  while(t--) solve();
  return 0;
}
